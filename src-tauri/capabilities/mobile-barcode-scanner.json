{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-barcode-scanner",
  "description": "Mobile-only barcode scanner permission for the main window",
  "windows": [
    "main"
  ],
  "platforms": [
    "android",
    "iOS"
  ],
  "permissions": [
    "barcode-scanner:allow-scan",
    "barcode-scanner:allow-cancel",
    "barcode-scanner:allow-request-permissions"
  ]
}
